---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Careers"
  description="Join the Alved team. We're hiring Direct Support Professionals who care about making a real difference in people's lives."
>

  <!-- PAGE HERO -->
  <section class="page-hero" aria-label="Careers at Alved">
    <div class="wrap page-hero-inner reveal">
      <span class="eyebrow">Careers</span>
      <h1>Make a difference every day.</h1>
      <p class="lead">At Alved, our Direct Support Professionals are the heart of everything we do. If you care about helping people live meaningful, independent lives — we want to hear from you.</p>
      <a href="#apply" class="btn btn-gold">Apply Now</a>
    </div>
  </section>

  <!-- WHY WORK HERE -->
  <section class="why-section" aria-labelledby="why-heading">
    <div class="why-bg-shape" aria-hidden="true"></div>
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">Why Alved</span>
        <h2 id="why-heading">A team that shows up for each other</h2>
        <p>We believe the people who support our individuals deserve the same care, respect, and dignity we provide to the people we serve.</p>
      </div>
      <div class="why-grid" role="list">
        <article class="why-card reveal" role="listitem">
          <div class="why-icon" aria-hidden="true">🌟</div>
          <h3>Meaningful Work</h3>
          <p>Every day you show up, you make a real difference in someone's life. This work matters — and we never lose sight of that.</p>
        </article>
        <article class="why-card reveal reveal--delay" role="listitem">
          <div class="why-icon" aria-hidden="true">📚</div>
          <h3>Training & Support</h3>
          <p>We provide thorough onboarding, ongoing training, and the support you need to do your job well and grow in your role.</p>
        </article>
        <article class="why-card reveal reveal--delay-2" role="listitem">
          <div class="why-icon" aria-hidden="true">🤝</div>
          <h3>Respectful Environment</h3>
          <p>We treat our team members the same way we treat the individuals we serve — with dignity, respect, and genuine care.</p>
        </article>
        <article class="why-card reveal reveal--delay-3" role="listitem">
          <div class="why-icon" aria-hidden="true">📅</div>
          <h3>Flexible Scheduling</h3>
          <p>We offer both full-time and part-time positions with scheduling that works around your life, not just ours.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- EDITORIAL PHOTOS -->
  <section class="editorial-section" aria-labelledby="editorial-heading">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">Life at Alved</span>
        <h2 id="editorial-heading">What the work actually looks like</h2>
      </div>
      <div class="editorial-row reveal">
        <div class="editorial-img">
          <img src="https://images.unsplash.com/photo-1576765608535-5f04d1e3f289?w=800&q=80" alt="A Direct Support Professional working alongside an individual in the community" loading="lazy" />
        </div>
        <div class="editorial-text">
          <span class="ed-tag">Direct Support</span>
          <h3>You go where the individual goes</h3>
          <p>As a DSP, your work happens at home, in the community, at work sites, and during recreational activities. No two days look the same — and that's part of what makes it rewarding.</p>
        </div>
      </div>
      <div class="editorial-row editorial-row--flip reveal">
        <div class="editorial-text">
          <span class="ed-tag">Real Impact</span>
          <h3>Small moments, big difference</h3>
          <p>Whether it's helping someone learn a new skill, supporting a community outing, or just being a consistent and caring presence — the work you do shapes lives in real, lasting ways.</p>
        </div>
        <div class="editorial-img">
          <img src="https://images.unsplash.com/photo-1491438590914-bc09fcaaf77a?w=800&q=80" alt="Support staff and individuals participating in a community activity together" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- OPEN POSITIONS -->
  <section class="positions-section" aria-labelledby="positions-heading">
    <div class="positions-bg-shape" aria-hidden="true"></div>
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">Open Positions</span>
        <h2 id="positions-heading">We're currently hiring</h2>
        <p>All positions work directly with individuals with intellectual and developmental disabilities across the Indianapolis area.</p>
      </div>
      <div class="positions-list reveal" role="list">
        <article class="position-card" role="listitem">
          <div class="position-info">
            <h3>Direct Support Professional</h3>
            <div class="position-meta">
              <span class="meta-tag">Full-time</span>
              <span class="meta-tag">Part-time</span>
              <span class="meta-tag">Indianapolis area</span>
            </div>
          </div>
          <a href="#apply" class="btn btn-primary">Apply</a>
        </article>
        <article class="position-card" role="listitem">
          <div class="position-info">
            <h3>Community Habilitation Support Staff (CIH)</h3>
            <div class="position-meta">
              <span class="meta-tag">Part-time</span>
              <span class="meta-tag">Flexible hours</span>
              <span class="meta-tag">Community based</span>
            </div>
          </div>
          <a href="#apply" class="btn btn-primary">Apply</a>
        </article>
        <article class="position-card" role="listitem">
          <div class="position-info">
            <h3>Respite Care Provider</h3>
            <div class="position-meta">
              <span class="meta-tag">Part-time</span>
              <span class="meta-tag">Weekend availability helpful</span>
            </div>
          </div>
          <a href="#apply" class="btn btn-primary">Apply</a>
        </article>
      </div>
    </div>
  </section>

  <!-- APPLICATION FORM -->
  <section class="apply-section" aria-labelledby="apply-heading" id="apply">
    <div class="apply-bg-shape" aria-hidden="true"></div>
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">Apply</span>
        <h2 id="apply-heading">Employment Application</h2>
        <p>Complete all fields below. Applications are actively considered for 3 months after submission. Equal opportunity employer.</p>
      </div>

      <div class="app-form reveal" role="form" aria-label="Employment application form">

        <fieldset class="form-section">
          <legend>Personal Information</legend>
          <div class="form-grid">
            <div class="field">
              <label for="fname">First Name <span class="required" aria-label="required">*</span></label>
              <input type="text" id="fname" name="fname" autocomplete="given-name" required />
            </div>
            <div class="field">
              <label for="lname">Last Name <span class="required" aria-label="required">*</span></label>
              <input type="text" id="lname" name="lname" autocomplete="family-name" required />
            </div>
            <div class="field">
              <label for="email">Email Address <span class="required" aria-label="required">*</span></label>
              <input type="email" id="email" name="email" autocomplete="email" required />
            </div>
            <div class="field">
              <label for="phone">Phone Number <span class="required" aria-label="required">*</span></label>
              <input type="tel" id="phone" name="phone" autocomplete="tel" required />
            </div>
            <div class="field field--full">
              <label for="address">Street Address</label>
              <input type="text" id="address" name="address" autocomplete="street-address" />
            </div>
          </div>
        </fieldset>

        <fieldset class="form-section">
          <legend>Position</legend>
          <div class="form-grid">
            <div class="field">
              <label for="position">Position Applying For <span class="required" aria-label="required">*</span></label>
              <select id="position" name="position" required>
                <option value="" disabled selected>Select a position</option>
                <option>Direct Support Professional</option>
                <option>Community Habilitation Support Staff (CIH)</option>
                <option>Respite Care Provider</option>
              </select>
            </div>
            <div class="field">
              <label for="type">Employment Type <span class="required" aria-label="required">*</span></label>
              <select id="type" name="type" required>
                <option value="" disabled selected>Select type</option>
                <option>Full-time</option>
                <option>Part-time</option>
                <option>Either</option>
              </select>
            </div>
            <div class="field field--full">
              <label for="availability">Availability <span class="required" aria-label="required">*</span></label>
              <input type="text" id="availability" name="availability" placeholder="e.g. Weekdays, evenings, weekends" required />
            </div>
          </div>
        </fieldset>

        <fieldset class="form-section">
          <legend>Background & Experience</legend>
          <div class="form-grid">
            <div class="field field--full">
              <label for="education">Highest Level of Education</label>
              <select id="education" name="education">
                <option value="" disabled selected>Select</option>
                <option>High School Diploma / GED</option>
                <option>Some College</option>
                <option>Associate's Degree</option>
                <option>Bachelor's Degree</option>
                <option>Graduate Degree</option>
              </select>
            </div>
            <div class="field field--full">
              <label for="experience">Relevant Experience</label>
              <textarea id="experience" name="experience" rows="4" placeholder="Tell us about any experience supporting individuals with I/DD, caregiving, or related work."></textarea>
            </div>
            <div class="field field--full">
              <label for="why">Why do you want to work at Alved?</label>
              <textarea id="why" name="why" rows="3" placeholder="Share what draws you to this kind of work."></textarea>
            </div>
          </div>
        </fieldset>

        <fieldset class="form-section">
          <legend>Consent & Acknowledgment</legend>
          <div class="consent-list">
            <div class="consent-item">
              <input type="checkbox" id="bgcheck" name="bgcheck" required />
              <label for="bgcheck">I consent to a criminal history background check and an abuse/neglect registry check as required for this position. <span class="required" aria-label="required">*</span></label>
            </div>
            <div class="consent-item">
              <input type="checkbox" id="dspregistry" name="dspregistry" required />
              <label for="dspregistry">I understand that Indiana requires Direct Support Professionals to be registered with the state DSP Registry before providing direct support services, effective January 1, 2026. <span class="required" aria-label="required">*</span></label>
            </div>
            <div class="consent-item">
              <input type="checkbox" id="eeo" name="eeo" required />
              <label for="eeo">I acknowledge that Alved Services, LLC is an equal opportunity employer and does not discriminate based on race, color, sex, age, national origin, disability, or any other protected category. I certify that all information in this application is accurate to the best of my knowledge. <span class="required" aria-label="required">*</span></label>
            </div>
          </div>
          <p class="form-note">This application will be actively considered for 3 months after submission. To be considered after that period, a new application must be submitted.</p>
        </fieldset>

        <div class="form-submit">
          <button type="submit" class="btn btn-gold btn-submit">Submit Application</button>
          <p class="form-note">Fields marked <span class="required" aria-label="required">*</span> are required.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="careers-cta" aria-label="Questions about careers">
    <div class="cta-bg-shape" aria-hidden="true"></div>
    <div class="wrap careers-cta-inner reveal">
      <h2>Questions before you apply?</h2>
      <p>We're happy to answer any questions about working at Alved before you submit your application.</p>
      <a href="/contact" class="btn btn-ghost-light">Get in Touch</a>
    </div>
  </section>

</Layout>

<style>
  /* PAGE HERO */
  .page-hero {
    position: relative;
    padding: 100px 0 90px;
    overflow: hidden;
  }
  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=1600&q=80') center/cover no-repeat;
    z-index: 0;
  }
  .page-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(20,42,69,0.93) 0%, rgba(31,58,95,0.82) 60%, rgba(31,58,95,0.65) 100%);
    z-index: 1;
  }
  .page-hero-inner { position: relative; z-index: 2; max-width: 700px; }
  .page-hero .eyebrow { color: var(--gold-soft); }
  .page-hero h1 { color: var(--white); font-size: clamp(2.2rem, 4vw, 3.2rem); margin-bottom: 18px; }
  .page-hero .lead { color: rgba(255,255,255,0.82); font-size: 1.1rem; line-height: 1.7; max-width: 580px; margin-bottom: 28px; }
  .btn-gold { background: var(--gold); color: var(--navy-deep); font-weight: 700; }
  .btn-gold:hover { background: #a07820; transform: translateY(-1px); }

  /* WHY SECTION */
  .why-section { padding: var(--section-pad) 0; position: relative; overflow: hidden; }
  .why-bg-shape { position: absolute; top: -100px; right: -100px; width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(184,144,44,0.06) 0%, transparent 70%); pointer-events: none; }
  .section-head { max-width: 580px; margin-bottom: 44px; }
  .section-head h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); margin-bottom: 10px; }
  .section-head p { color: var(--ink-soft); }
  .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; position: relative; z-index: 1; }
  .why-card { background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px 22px; border-bottom: 4px solid var(--gold-soft); transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease; }
  .why-card:hover { transform: translateY(-3px); box-shadow: 0 12px 30px -10px rgba(31,58,95,0.15); border-bottom-color: var(--gold); }
  .why-icon { font-size: 1.8rem; margin-bottom: 14px; }
  .why-card h3 { font-size: 1rem; margin-bottom: 8px; }
  .why-card p { color: var(--ink-soft); font-size: 0.9rem; margin: 0; line-height: 1.6; }

  /* EDITORIAL */
  .editorial-section { padding: var(--section-pad) 0; background: var(--bg-alt); }
  .editorial-row { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: center; margin-bottom: 60px; }
  .editorial-row:last-child { margin-bottom: 0; }
  .editorial-img { border-radius: var(--radius); overflow: hidden; }
  .editorial-img img { width: 100%; height: 320px; object-fit: cover; display: block; }
  .ed-tag { display: inline-block; background: var(--gold-soft); color: var(--navy-deep); font-size: 0.75rem; font-weight: 700; padding: 4px 12px; border-radius: 20px; margin-bottom: 14px; }
  .editorial-text h3 { font-family: var(--font-head); font-size: 1.4rem; color: var(--navy); margin-bottom: 12px; }
  .editorial-text p { color: var(--ink-soft); font-size: 0.95rem; line-height: 1.7; }

  /* POSITIONS */
  .positions-section { padding: var(--section-pad) 0; position: relative; overflow: hidden; }
  .positions-bg-shape { position: absolute; bottom: -80px; left: -80px; width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(31,58,95,0.05) 0%, transparent 70%); pointer-events: none; }
  .positions-list { display: grid; gap: 14px; position: relative; z-index: 1; }
  .position-card { background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px 28px; display: flex; align-items: center; justify-content: space-between; gap: 20px; transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .position-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px -8px rgba(31,58,95,0.14); }
  .position-info h3 { font-size: 1.05rem; color: var(--navy); margin-bottom: 8px; }
  .position-meta { display: flex; gap: 8px; flex-wrap: wrap; }
  .meta-tag { background: var(--bg-alt); color: var(--ink-soft); font-size: 0.78rem; font-weight: 600; padding: 3px 10px; border-radius: 16px; border: 1px solid var(--border); }
  .btn-primary { background: var(--navy); color: var(--white); font-weight: 700; flex-shrink: 0; }
  .btn-primary:hover { background: var(--navy-deep); transform: translateY(-1px); }

  /* APPLICATION FORM */
  .apply-section { background: var(--bg-alt); padding: var(--section-pad) 0; position: relative; overflow: hidden; }
  .apply-bg-shape { position: absolute; top: -100px; right: -100px; width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(184,144,44,0.05) 0%, transparent 70%); pointer-events: none; }
  .app-form { background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); padding: 44px; position: relative; z-index: 1; }
  .form-section { border: none; padding: 0; margin-bottom: 40px; }
  .form-section legend { font-family: var(--font-head); font-size: 1.05rem; color: var(--navy); font-weight: 700; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid var(--gold-soft); width: 100%; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .field { display: flex; flex-direction: column; gap: 6px; }
  .field--full { grid-column: 1 / -1; }
  label { font-weight: 600; font-size: 0.9rem; color: var(--ink); }
  .required { color: var(--gold); font-weight: 700; }
  input[type="text"],
  input[type="email"],
  input[type="tel"],
  select,
  textarea {
    font-family: inherit;
    font-size: 0.95rem;
    padding: 11px 14px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    color: var(--ink);
    transition: border-color 0.2s;
  }
  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--navy);
    box-shadow: 0 0 0 3px rgba(31,58,95,0.1);
  }
  textarea { resize: vertical; min-height: 100px; }
  .consent-list { display: grid; gap: 16px; margin-bottom: 20px; }
  .consent-item { display: flex; gap: 12px; align-items: flex-start; background: var(--bg); border-radius: 8px; padding: 14px 16px; border: 1px solid var(--border); }
  .consent-item input[type="checkbox"] { margin-top: 3px; width: 18px; height: 18px; flex-shrink: 0; accent-color: var(--navy); cursor: pointer; }
  .consent-item label { font-weight: 400; font-size: 0.9rem; color: var(--ink-soft); line-height: 1.55; cursor: pointer; }
  .form-note { font-size: 0.82rem; color: var(--ink-soft); margin: 14px 0 0; line-height: 1.5; }
  .form-submit { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; margin-top: 10px; }
  .btn-submit { font-size: 1rem; padding: 15px 32px; }

  /* CTA */
  .careers-cta { background: var(--navy); padding: 64px 0; position: relative; overflow: hidden; }
  .cta-bg-shape { position: absolute; top: -80px; right: -80px; width: 400px; height: 400px; border-radius: 50%; background: rgba(184,144,44,0.08); pointer-events: none; }
  .careers-cta-inner { text-align: center; max-width: 560px; margin: 0 auto; position: relative; z-index: 1; }
  .careers-cta h2 { color: var(--white); font-size: clamp(1.5rem, 3vw, 2rem); margin-bottom: 12px; }
  .careers-cta p { color: rgba(255,255,255,0.75); margin-bottom: 28px; }
  .btn-ghost-light { background: transparent; color: var(--white); border: 2px solid rgba(255,255,255,0.5); font-weight: 700; }
  .btn-ghost-light:hover { background: rgba(255,255,255,0.1); color: var(--white); }

  /* ANIMATIONS */
  .reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.in { opacity: 1; transform: none; }
  .reveal--delay   { transition-delay: 0.15s; }
  .reveal--delay-2 { transition-delay: 0.3s; }
  .reveal--delay-3 { transition-delay: 0.45s; }

  /* MOBILE */
  @media (max-width: 880px) {
    .why-grid { grid-template-columns: 1fr 1fr; }
    .editorial-row { grid-template-columns: 1fr; }
    .editorial-row--flip .editorial-img { order: -1; }
    .form-grid { grid-template-columns: 1fr; }
    .app-form { padding: 28px 20px; }
    .position-card { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 540px) {
    .why-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in'); observer.unobserve(e.target); }
    }),
    { threshold: 0.1 }
  );
  reveals.forEach(el => observer.observe(el));
</script>