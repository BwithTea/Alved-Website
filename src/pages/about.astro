---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="About Us" 
  description="Learn about Alved Services — our mission, vision, values, and the meaning behind our name."
>

  <!-- ====== PAGE HERO ====== -->
  <section class="page-hero" aria-label="About Alved">
    <div class="wrap page-hero-inner">
      <div class="reveal">
        <span class="eyebrow">About Us</span>
        <h1>Light and strength, together.</h1>
        <p class="lead">
          We believe every individual deserves the opportunity to shine. 
          Alved was built on that belief — and everything we do flows from it.
        </p>
      </div>
    </div>
  </section>

  <!-- ====== MISSION & VISION ====== -->
  <section class="mv-section" aria-labelledby="mv-heading">
    <div class="wrap">
      <h2 id="mv-heading" class="sr-only">Mission and Vision</h2>
      <div class="mv-grid">
        <div class="mv-card reveal">
          <span class="eyebrow">Our Mission</span>
          <h3>Why we exist</h3>
          <p>
            We help people with intellectual and developmental disabilities 
            build skills, gain independence, and belong in their communities 
            through caring, individualized support.
          </p>
        </div>
        <div class="mv-card reveal reveal--delay">
          <span class="eyebrow">Our Vision</span>
          <h3>What we're working toward</h3>
          <p>
            Empower people with intellectual and developmental disabilities 
            to live meaningful, self-directed lives.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== NAME MEANING ====== -->
  <section class="name-section" aria-labelledby="name-heading">
    <div class="wrap name-inner">
      <div class="name-text reveal">
        <span class="eyebrow">What "Alved" Means</span>
        <h2 id="name-heading">A name with purpose</h2>
        <p>
          The name Alved is not accidental. It carries two meanings that define 
          how we show up for every individual and family we serve.
        </p>
        <div class="name-pair">
          <div class="name-meaning">
            <div class="meaning-mark meaning-mark--sun" aria-hidden="true"></div>
            <div>
              <strong>Alva — Light, Clarity & Hope</strong>
              <p>We bring light to the lives of individuals with I/DD through 
              compassionate, person-centered support. Every person deserves 
              the opportunity to shine.</p>
            </div>
          </div>
          <div class="name-meaning">
            <div class="meaning-mark meaning-mark--shield" aria-hidden="true"></div>
            <div>
              <strong>Edith — Blessed Strength & Resilience</strong>
              <p>We walk alongside individuals and families with strength, care, 
              and commitment — helping them face challenges and celebrate 
              progress every step of the way.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="name-visual reveal reveal--delay" aria-hidden="true">
        <div class="name-card">
          <div class="big-mark">
            <div class="big-sun"></div>
            <div class="big-shield"></div>
          </div>
          <p class="brand-promise">
            "At Alved, we promise to deliver caring, individualized support 
            that respects choice, builds independence, and promotes belonging — 
            every person, every day."
          </p>
          <span class="promise-label">Our Brand Promise</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== VALUES ====== -->
  <section class="values-section" aria-labelledby="values-heading">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">Our Values</span>
        <h2 id="values-heading">What guides everything we do</h2>
      </div>

      <div class="values-grid" role="list">

        <article class="value-card reveal" role="listitem">
          <div class="value-icon" aria-hidden="true">⭐</div>
          <h3>Person-Centeredness</h3>
          <p>We honor each individual's choices, strengths, culture, and goals. 
          Support is shaped by the individual — not the system.</p>
        </article>

        <article class="value-card reveal reveal--delay" role="listitem">
          <div class="value-icon" aria-hidden="true">🛡️</div>
          <h3>Dignity & Respect</h3>
          <p>We uphold the rights, privacy, and dignity of every person while 
          promoting self-determination and informed decision-making.</p>
        </article>

        <article class="value-card reveal reveal--delay-2" role="listitem">
          <div class="value-icon" aria-hidden="true">📈</div>
          <h3>Independence & Skill Building</h3>
          <p>We focus on developing life skills and natural supports that 
          increase independence over time.</p>
        </article>

        <article class="value-card reveal reveal--delay" role="listitem">
          <div class="value-icon" aria-hidden="true">🏘️</div>
          <h3>Community Inclusion & Belonging</h3>
          <p>We actively support meaningful participation in community life, 
          relationships, employment, and activities chosen by the individual.</p>
        </article>

        <article class="value-card reveal reveal--delay-2" role="listitem">
          <div class="value-icon" aria-hidden="true">💚</div>
          <h3>Health, Safety & Well-Being</h3>
          <p>We balance safety with autonomy and use positive support to 
          promote each individual's overall well-being.</p>
        </article>

        <article class="value-card reveal reveal--delay-3" role="listitem">
          <div class="value-icon" aria-hidden="true">✨</div>
          <h3>Quality Care & Growth</h3>
          <p>We provide quality care and embrace change where it helps 
          the individuals we support.</p>
        </article>

      </div>
    </div>
  </section>

  <!-- ====== ACCREDITATION ====== -->
  <section class="accred-section" aria-labelledby="accred-heading">
    <div class="wrap accred-inner reveal">
      <div>
        <span class="eyebrow">Accreditation & Approval</span>
        <h2 id="accred-heading">State certified. Independently accredited.</h2>
        <p>
          Alved is approved by the Indiana Bureau of Developmental Disabilities 
          Services (BDDS) and accredited by the Council on Quality and Leadership (CQL) 
          for the following programs:
        </p>
        <ul class="accred-list" role="list">
          <li>Community Integration Waiver</li>
          <li>Family Support Waiver</li>
          <li>Money Follows the Person Program</li>
        </ul>
      </div>
      <div class="accred-badges" aria-label="Accreditation badges">
        <div class="accred-badge">
          <strong>BDDS</strong>
          <span>Bureau of Developmental<br/>Disabilities Services</span>
        </div>
        <div class="accred-badge accred-badge--gold">
          <strong>CQL</strong>
          <span>Council on Quality<br/>and Leadership</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== CTA ====== -->
  <section class="about-cta" aria-label="Get in touch">
    <div class="wrap about-cta-inner reveal">
      <h2>Want to learn more about how we can help?</h2>
      <p>We're here to answer questions and help you understand your options.</p>
      <div class="btn-row">
        <a href="/contact" class="btn btn-primary">Contact Us</a>
        <a href="/services" class="btn btn-ghost">See Our Services</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ====== PAGE HERO ====== */
  .page-hero {
    background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%);
    padding: 90px 0 80px;
    position: relative;
    overflow: hidden;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 80% 50%, rgba(184,144,44,0.12) 0%, transparent 60%);
  }

  .page-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .page-hero .eyebrow { color: var(--gold-soft); }

  .page-hero h1 {
    color: var(--white);
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 18px;
  }

  .page-hero .lead {
    color: rgba(255,255,255,0.82);
    font-size: 1.12rem;
    line-height: 1.7;
    max-width: 580px;
  }

  /* Screen reader only utility */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* ====== MISSION & VISION ====== */
  .mv-section {
    padding: var(--section-pad) 0;
  }

  .mv-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .mv-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 36px;
  }

  .mv-card h3 {
    font-size: 1.3rem;
    margin: 8px 0 14px;
  }

  .mv-card p {
    color: var(--ink-soft);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  /* ====== NAME MEANING ====== */
  .name-section {
    background: var(--bg-alt);
    padding: var(--section-pad) 0;
  }

  .name-inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: center;
  }

  .name-text h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin-bottom: 14px;
  }

  .name-text > p {
    color: var(--ink-soft);
    margin-bottom: 30px;
  }

  .name-pair {
    display: grid;
    gap: 24px;
  }

  .name-meaning {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .meaning-mark {
    flex-shrink: 0;
    margin-top: 4px;
  }

  .meaning-mark--sun {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 0 4px var(--gold-soft);
  }

  .meaning-mark--shield {
    width: 22px;
    height: 26px;
    border: 2.5px solid var(--navy);
    border-radius: 3px 3px 10px 10px;
    background: var(--bg);
  }

  .name-meaning strong {
    display: block;
    color: var(--navy);
    font-family: var(--font-head);
    font-size: 1rem;
    margin-bottom: 6px;
  }

  .name-meaning p {
    color: var(--ink-soft);
    font-size: 0.95rem;
    margin: 0;
  }

  .name-card {
    background: var(--navy);
    border-radius: var(--radius);
    padding: 40px;
    position: relative;
    overflow: hidden;
  }

  .name-card::before {
    content: '';
    position: absolute;
    top: -50px;
    right: -50px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: rgba(184,144,44,0.12);
  }

  .big-mark {
    display: flex;
    gap: 14px;
    margin-bottom: 28px;
    position: relative;
    z-index: 1;
  }

  .big-sun {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 0 8px rgba(184,144,44,0.2);
  }

  .big-shield {
    width: 38px;
    height: 44px;
    border: 3.5px solid rgba(255,255,255,0.5);
    border-radius: 5px 5px 16px 16px;
  }

  .brand-promise {
    font-family: var(--font-head);
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--white);
    margin-bottom: 18px;
    position: relative;
    z-index: 1;
  }

  .promise-label {
    color: var(--gold-soft);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ====== VALUES ====== */
  .values-section {
    padding: var(--section-pad) 0;
  }

  .section-head {
    max-width: 580px;
    margin-bottom: 44px;
  }

  .section-head h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin-top: 8px;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .value-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .value-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px -10px rgba(31,58,95,0.15);
  }

  .value-icon {
    font-size: 1.8rem;
    margin-bottom: 14px;
  }

  .value-card h3 {
    font-size: 1.05rem;
    margin-bottom: 10px;
  }

  .value-card p {
    color: var(--ink-soft);
    font-size: 0.93rem;
    margin: 0;
    line-height: 1.6;
  }

  /* ====== ACCREDITATION ====== */
  .accred-section {
    background: var(--bg-alt);
    padding: var(--section-pad) 0;
  }

  .accred-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 60px;
    align-items: center;
  }

  .accred-inner h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin-bottom: 14px;
  }

  .accred-inner > div > p {
    color: var(--ink-soft);
    margin-bottom: 20px;
    max-width: 560px;
  }

  .accred-list {
    list-style: none;
    display: grid;
    gap: 8px;
  }

  .accred-list li {
    display: flex;
    gap: 10px;
    align-items: center;
    font-size: 0.95rem;
  }

  .accred-list li::before {
    content: "✓";
    color: var(--sage);
    font-weight: 700;
    flex-shrink: 0;
  }

  .accred-badges {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .accred-badge {
    background: var(--white);
    border: 2px solid var(--navy);
    border-radius: var(--radius);
    padding: 22px 28px;
    text-align: center;
    min-width: 160px;
  }

  .accred-badge strong {
    display: block;
    font-family: var(--font-head);
    font-size: 1.8rem;
    color: var(--navy);
    margin-bottom: 6px;
  }

  .accred-badge span {
    font-size: 0.78rem;
    color: var(--ink-soft);
    line-height: 1.4;
  }

  .accred-badge--gold {
    background: var(--navy);
    border-color: var(--navy);
  }

  .accred-badge--gold strong {
    color: var(--gold);
  }

  .accred-badge--gold span {
    color: rgba(255,255,255,0.7);
  }

  /* ====== CTA ====== */
  .about-cta {
    background: var(--navy);
    padding: 64px 0;
  }

  .about-cta-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .about-cta h2 {
    color: var(--white);
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 12px;
  }

  .about-cta p {
    color: rgba(255,255,255,0.75);
    margin-bottom: 28px;
  }

  .btn-row {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .about-cta .btn-primary {
    background: var(--gold);
    color: var(--navy-deep);
  }

  .about-cta .btn-ghost {
    border-color: rgba(255,255,255,0.5);
    color: var(--white);
  }

  .about-cta .btn-ghost:hover {
    background: rgba(255,255,255,0.1);
    color: var(--white);
  }

  /* ====== ANIMATIONS ====== */
  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.in { opacity: 1; transform: none; }
  .reveal--delay  { transition-delay: 0.15s; }
  .reveal--delay-2 { transition-delay: 0.3s; }
  .reveal--delay-3 { transition-delay: 0.45s; }

  /* ====== MOBILE ====== */
  @media (max-width: 880px) {
    .mv-grid,
    .name-inner,
    .accred-inner { grid-template-columns: 1fr; }
    .values-grid { grid-template-columns: 1fr 1fr; }
    .accred-badges { flex-direction: row; }
  }

  @media (max-width: 540px) {
    .values-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  reveals.forEach(el => observer.observe(el));
</script>