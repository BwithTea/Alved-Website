---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Our Services"
  description="Alved Services provides Day Habilitation, Residential Habilitation, Participant Assistance and Care, and Respite services for adults in Marion County, Indiana."
>

  <!-- PAGE HERO -->
  <section class="page-hero" aria-label="Our Services">
    <div class="wrap page-hero-inner reveal">
      <span class="eyebrow">Our Services</span>
      <h1>Support built around you</h1>
      <p class="lead">Alved Services is a residential services provider offering individualized support for adults with developmental disabilities in Marion County. Every service is planned together with you, your family, and your support team.</p>
    </div>
  </section>

  <!-- SERVICE CARDS -->
  <section class="services-section" aria-labelledby="services-heading">
    <div class="services-bg-shape" aria-hidden="true"></div>
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">What We Offer</span>
        <h2 id="services-heading">Our approved services</h2>
        <p>All services are available through Indiana's Medicaid Waiver programs for eligible adults at no cost to you.</p>
      </div>
      <div class="services-grid" role="list">

        <article class="service-card reveal" role="listitem" id="day-hab">
          <div class="service-card-top">
            <span class="abbr">DAY</span>
            <span class="service-tag">Day Program</span>
          </div>
          <h3>Day Habilitation</h3>
          <p>Structured daytime programming focused on skill-building, community access, and meaningful daily activities.</p>
          <a href="/contact" class="service-link">Press here to contact us for more information</a>
        </article>

        <article class="service-card reveal reveal--delay" role="listitem" id="rhs">
          <div class="service-card-top">
            <span class="abbr">RHS</span>
            <span class="service-tag">Home Based</span>
          </div>
          <h3>Residential Habilitation & Support</h3>
          <p>Support provided in your home to help you build the skills you need for everyday life.</p>
          <ul class="service-list" role="list">
            <li>Teaching and reinforcing self-care skills</li>
            <li>Medication assistance</li>
          </ul>
        </article>

        <article class="service-card reveal" role="listitem" id="pac">
          <div class="service-card-top">
            <span class="abbr">PAC</span>
            <span class="service-tag">Personal Care</span>
          </div>
          <h3>Participant Assistance & Care</h3>
          <p>Hands-on assistance with your daily personal needs and community participation.</p>
          <ul class="service-list" role="list">
            <li>Personal hygiene and grooming</li>
            <li>Meal planning and preparation</li>
            <li>Managing household tasks</li>
            <li>Reporting changes in health or behavior</li>
            <li>Transportation to appointments, work, shopping, and community activities</li>
            <li>Promoting independence through prompts and self-advocacy</li>
            <li>Supporting communication</li>
            <li>Ensuring your safety</li>
          </ul>
        </article>

        <article class="service-card reveal reveal--delay" role="listitem" id="respite">
          <div class="service-card-top">
            <span class="abbr">RESP</span>
            <span class="service-tag">Family Support</span>
          </div>
          <h3>Respite</h3>
          <p>Short-term care so your family and caregivers can rest, knowing you are in safe and caring hands.</p>
          <ul class="service-list" role="list">
            <li>Protective supervision to ensure your safety</li>
            <li>Responding to your routine needs</li>
            <li>Personal care assistance</li>
            <li>Maintaining your lifestyle and daily routine</li>
          </ul>
        </article>

      </div>
    </div>
  </section>
    <!-- WHERE YOU LIVE SECTION -->
  <section class="living-section" aria-labelledby="living-heading">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">Where You Live</span>
        <h2 id="living-heading">Everyone's living situation is different — and that's okay</h2>
        <p>Whether you live with your family, on your own, or with roommates, Alved Services can provide support that fits your life.</p>
      </div>
      <div class="living-grid reveal">

        <div class="living-card">
          <div class="living-icon" aria-hidden="true">👨‍👩‍👧</div>
          <h3>Living with family</h3>
          <p>If your family members work during the day, we can be there to support you while they are away through the <strong>Participant Assistance and Care (PAC) Waiver</strong>.</p>
        </div>

        <div class="living-card">
          <div class="living-icon" aria-hidden="true">🏠</div>
          <h3>Living on your own or with roommates</h3>
          <p>We provide <strong>Residential Habilitation and Support</strong> in your home to help you build daily living skills and become more independent.</p>
        </div>

        <div class="living-card">
          <div class="living-icon" aria-hidden="true">☕</div>
          <h3>When your caregiver needs a break</h3>
          <p>We offer <strong>Respite services</strong> so your caregiver can rest — whether that is for a few hours, overnight, or a full weekend.</p>
        </div>

        <div class="living-card">
          <div class="living-icon" aria-hidden="true">🔑</div>
          <h3>Ready to move into your own home</h3>
          <p>If you want to leave a long-term living facility and move into your own place, we can help you plan and make that transition on your terms.</p>
        </div>

      </div>
      <p class="living-footer reveal">You choose where and how you want to live. We are here to support your goals.</p>
    </div>
  </section>

  <!-- DSP SECTION -->
  <section class="dsp-section" aria-labelledby="dsp-heading">
    <div class="dsp-bg-shape" aria-hidden="true"></div>
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">Direct Support Professionals</span>
        <h2 id="dsp-heading">What your DSP will do for you</h2>
        <p>Our Direct Support Professionals (DSPs) are trained, caring staff who work directly with you every day. Here is what they will support you with across all of our services.</p>
      </div>
      <div class="dsp-grid reveal">
        <div class="dsp-card">
          <div class="dsp-icon" aria-hidden="true">🏠</div>
          <h3>In Your Home</h3>
          <ul role="list">
            <li>Providing quality care in your home as needed</li>
            <li>Assisting with personal hygiene, bathing, grooming, and dressing</li>
            <li>Meal preparation and assistance with dining</li>
            <li>Keeping your home clean, safe, and well maintained</li>
            <li>Medication assistance and health monitoring</li>
          </ul>
        </div>
        <div class="dsp-card">
          <div class="dsp-icon" aria-hidden="true">🏘️</div>
          <h3>In Your Community</h3>
          <ul role="list">
            <li>Transportation to appointments, work, shopping, and activities</li>
            <li>Supporting you to take part in community life</li>
            <li>Helping you build and maintain relationships</li>
            <li>Supporting employment and volunteer opportunities</li>
          </ul>
        </div>
        <div class="dsp-card">
          <div class="dsp-icon" aria-hidden="true">📈</div>
          <h3>Your Independence</h3>
          <ul role="list">
            <li>Teaching and reinforcing daily living skills</li>
            <li>Providing prompts and guidance, not doing it for you</li>
            <li>Supporting your communication and self-advocacy</li>
            <li>Helping you make your own choices</li>
          </ul>
        </div>
        <div class="dsp-card">
          <div class="dsp-icon" aria-hidden="true">💚</div>
          <h3>Your Health & Safety</h3>
          <ul role="list">
            <li>Continuous monitoring of your health and safety</li>
            <li>Responding to health changes and emergencies</li>
            <li>Documenting your care accurately and on time</li>
            <li>Treating you with respect and dignity at all times</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- PHOTO CAROUSEL -->
  <section class="carousel-section" aria-labelledby="carousel-heading">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">Our Work in Action</span>
        <h2 id="carousel-heading">What support looks like every day</h2>
        <p>Real moments of care, skill-building, and community connection for the adults we support.</p>
      </div>
      <div class="slider-wrap reveal">
        <div class="slider-track" id="sliderTrack" role="region" aria-label="Photo slideshow" aria-live="polite">
          <div class="slide" role="group" aria-label="Slide 1 of 4">
            <img src="https://images.unsplash.com/photo-1576765608535-5f04d1e3f289?w=1200&q=80" alt="A support professional working alongside an adult individual in a community setting" />
            <div class="slide-caption">
              <span class="slide-tag">Day Habilitation</span>
              <h3>Structured days built around your goals</h3>
              <p>Day Habilitation gives you a place to build skills, connect with others, and take part in meaningful activities every day.</p>
            </div>
          </div>
          <div class="slide" role="group" aria-label="Slide 2 of 4">
            <img src="https://images.unsplash.com/photo-1582213782179-e0d53f98f2ca?w=1200&q=80" alt="Support professional assisting an individual with daily living skills at home" />
            <div class="slide-caption">
              <span class="slide-tag">Residential Habilitation</span>
              <h3>Learning skills for everyday life</h3>
              <p>Your DSP works with you at home to build the skills you need to live as independently as possible.</p>
            </div>
          </div>
          <div class="slide" role="group" aria-label="Slide 3 of 4">
            <img src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=1200&q=80" alt="Support professional helping an individual with personal care and community access" />
            <div class="slide-caption">
              <span class="slide-tag">Participant Assistance & Care</span>
              <h3>Personal care that respects your dignity</h3>
              <p>PAC support is tailored to your specific needs, helping you stay healthy, safe, and active in your community.</p>
            </div>
          </div>
          <div class="slide" role="group" aria-label="Slide 4 of 4">
            <img src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=1200&q=80" alt="Families and individuals in a relaxed, caring setting" />
            <div class="slide-caption">
              <span class="slide-tag">Respite</span>
              <h3>Peace of mind for your whole family</h3>
              <p>Respite care gives your family the break they need, knowing you are in safe, caring hands.</p>
            </div>
          </div>
        </div>
        <button class="slider-arrow slider-arrow--prev" id="prevBtn" aria-label="Previous slide">&#8592;</button>
        <button class="slider-arrow slider-arrow--next" id="nextBtn" aria-label="Next slide">&#8594;</button>
      </div>
      <div class="slider-controls">
        <div class="slider-dots" id="dotContainer" role="tablist" aria-label="Slideshow navigation">
          <button class="dot active" role="tab" aria-selected="true" aria-label="Go to slide 1"></button>
          <button class="dot" role="tab" aria-selected="false" aria-label="Go to slide 2"></button>
          <button class="dot" role="tab" aria-selected="false" aria-label="Go to slide 3"></button>
          <button class="dot" role="tab" aria-selected="false" aria-label="Go to slide 4"></button>
        </div>
        <button class="pause-btn" id="pauseBtn" aria-label="Pause slideshow">❚❚ Pause</button>
      </div>
    </div>
  </section>

  <!-- WAIVER CALLOUT -->
  <section class="waiver-callout" aria-labelledby="waiver-callout-heading">
    <div class="waiver-bg-shape" aria-hidden="true"></div>
    <div class="wrap waiver-inner reveal">
      <div class="waiver-text">
        <span class="eyebrow">Medicaid Waiver</span>
        <h2 id="waiver-callout-heading">These services may be covered at no cost to you</h2>
        <p>All of Alved Services' programs are available through Indiana's Medicaid Waiver programs. If you or your loved one qualifies, services are covered by Medicaid at no cost to you.</p>
        <a href="/waiver" class="btn btn-primary">Press here to Learn About the Waiver</a>
      </div>
      <div class="waiver-programs" aria-label="Approved waiver programs">
        <h3>Approved programs</h3>
        <ul role="list">
          <li>Community Integration Waiver</li>
          <li>Family Support Waiver</li>
          <li>Money Follows the Person Program</li>
          <li>Adult Day Services</li>
        </ul>
        <div class="waiver-badges">
          <span class="w-badge">Marion County Provider</span>
          <span class="w-badge">CQL Accredited</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="services-cta" aria-label="Get started">
    <div class="cta-bg-shape" aria-hidden="true"></div>
    <div class="wrap cta-inner reveal">
      <h2>Ready to get started?</h2>
      <p>Contact us to learn which services are right for you or your loved one.</p>
      <div class="btn-row">
        <a href="/contact" class="btn btn-gold">Press here to Contact Us</a>
        <a href="/careers" class="btn btn-ghost-light">Press here to Join Our Team</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero { position: relative; padding: 100px 0 90px; overflow: hidden; }
  .page-hero::before { content: ''; position: absolute; inset: 0; background: url('https://images.unsplash.com/photo-1576765608535-5f04d1e3f289?w=1600&q=80') center/cover no-repeat; z-index: 0; }
  .page-hero::after { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(20,42,69,0.93) 0%, rgba(31,58,95,0.82) 60%, rgba(31,58,95,0.65) 100%); z-index: 1; }
  .page-hero-inner { position: relative; z-index: 2; max-width: 720px; }
  .page-hero .eyebrow { color: var(--gold-soft); }
  .page-hero h1 { color: var(--white); font-size: clamp(2.2rem, 4vw, 3.2rem); margin-bottom: 18px; }
  .page-hero .lead { color: rgba(255,255,255,0.82); font-size: 1.1rem; line-height: 1.7; max-width: 580px; }

  .section-head { max-width: 580px; margin-bottom: 44px; }
  .section-head h2 { font-size: clamp(1.6rem, 3vw, 2.1rem); margin-bottom: 10px; }
  .section-head p { color: var(--ink-soft); }

  .services-section { padding: var(--section-pad) 0; position: relative; overflow: hidden; }
  .services-bg-shape { position: absolute; top: -100px; right: -100px; width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(184,144,44,0.06) 0%, transparent 70%); pointer-events: none; }
  .services-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; position: relative; z-index: 1; }
  .service-card { background: var(--white); border: 1px solid var(--border); border-left: 5px solid var(--gold); border-radius: var(--radius); padding: 32px; position: relative; overflow: hidden; transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .service-card::before { content: ''; position: absolute; top: -30px; right: -30px; width: 120px; height: 120px; border-radius: 50%; background: rgba(184,144,44,0.06); transition: transform 0.4s ease; pointer-events: none; }
  .service-card:hover::before { transform: scale(2.5); }
  .service-card:hover { transform: translateY(-3px); box-shadow: 0 14px 36px -10px rgba(31,58,95,0.18); }
  .service-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .abbr { font-family: var(--font-head); font-weight: 700; color: var(--navy); font-size: 1.8rem; }
  .service-tag { background: var(--gold-soft); color: var(--navy-deep); font-size: 0.75rem; font-weight: 700; padding: 4px 12px; border-radius: 20px; }
  .service-card h3 { font-size: 1.1rem; color: var(--ink); margin-bottom: 10px; }
  .service-card > p { color: var(--ink-soft); font-size: 0.93rem; line-height: 1.65; margin-bottom: 14px; }
  .service-list { list-style: none; display: grid; gap: 6px; margin-bottom: 0; }
  .service-list li { display: flex; gap: 8px; font-size: 0.88rem; color: var(--ink-soft); align-items: flex-start; }
  .service-list li::before { content: "✓"; color: var(--sage); font-weight: 700; flex-shrink: 0; }
  .service-link { display: inline-block; margin-top: 14px; font-size: 0.88rem; color: var(--navy); font-weight: 700; text-decoration: underline; }
  .service-link:hover { color: var(--gold); }

  .dsp-section { background: var(--bg-alt); padding: var(--section-pad) 0; position: relative; overflow: hidden; }
  .dsp-bg-shape { position: absolute; bottom: -80px; left: -80px; width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(31,58,95,0.05) 0%, transparent 70%); pointer-events: none; }
  .dsp-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; position: relative; z-index: 1; }
  .dsp-card { background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); padding: 26px 22px; border-top: 4px solid var(--navy); }
  .dsp-icon { font-size: 1.8rem; margin-bottom: 12px; }
  .dsp-card h3 { font-family: var(--font-head); font-size: 1rem; color: var(--navy); margin-bottom: 14px; }
  .dsp-card ul { list-style: none; display: grid; gap: 8px; }
  .dsp-card li { font-size: 0.88rem; color: var(--ink-soft); display: flex; gap: 8px; line-height: 1.5; }
  .dsp-card li::before { content: "→"; color: var(--gold); font-weight: 700; flex-shrink: 0; }

  .carousel-section { padding: var(--section-pad) 0; }
  .slider-wrap { position: relative; border-radius: var(--radius); overflow: hidden; width: 100%; background: var(--navy-deep); }
  .slider-track { display: flex; width: 100%; transition: transform 0.5s cubic-bezier(0.4,0,0.2,1); will-change: transform; }
  .slide { width: 100%; min-width: 100%; max-width: 100%; flex: 0 0 100%; position: relative; height: 460px; overflow: hidden; }
  .slide img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .slide-caption { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(20,42,69,0.95) 0%, rgba(20,42,69,0.6) 60%, transparent 100%); padding: 50px 40px 32px; color: var(--white); }
  .slide-tag { display: inline-block; background: var(--gold); color: var(--navy-deep); font-size: 0.72rem; font-weight: 700; padding: 4px 11px; border-radius: 14px; margin-bottom: 10px; }
  .slide-caption h3 { font-family: var(--font-head); font-size: 1.4rem; color: var(--white); margin-bottom: 8px; }
  .slide-caption p { font-size: 0.93rem; color: rgba(255,255,255,0.82); max-width: 560px; line-height: 1.6; }
  .slider-arrow { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.15); backdrop-filter: blur(6px); border: 1px solid rgba(255,255,255,0.25); color: var(--white); width: 46px; height: 46px; border-radius: 50%; font-size: 1.1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; z-index: 2; }
  .slider-arrow:hover { background: rgba(255,255,255,0.28); }
  .slider-arrow--prev { left: 18px; }
  .slider-arrow--next { right: 18px; }
  .slider-controls { display: flex; align-items: center; justify-content: center; gap: 18px; margin-top: 18px; }
  .slider-dots { display: flex; gap: 8px; }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border); cursor: pointer; border: none; padding: 0; transition: background 0.2s, width 0.2s; }
  .dot.active { background: var(--navy); width: 22px; border-radius: 4px; }
  .pause-btn { background: none; border: 1px solid var(--border); border-radius: 20px; padding: 5px 14px; font-size: 0.78rem; font-family: var(--font-body); color: var(--ink-soft); cursor: pointer; }
  .pause-btn:hover { background: var(--border); }

  .waiver-callout { padding: var(--section-pad) 0; position: relative; overflow: hidden; background: var(--bg-alt); }
  .waiver-bg-shape { position: absolute; bottom: -80px; left: -80px; width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(31,58,95,0.05) 0%, transparent 70%); pointer-events: none; }
  .waiver-inner { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 60px; align-items: center; position: relative; z-index: 1; }
  .waiver-text h2 { font-size: clamp(1.5rem, 2.5vw, 2rem); margin-bottom: 14px; }
  .waiver-text p { color: var(--ink-soft); margin-bottom: 24px; line-height: 1.7; }
  .btn-primary { background: var(--navy); color: var(--white); font-weight: 700; }
  .btn-primary:hover { background: var(--navy-deep); transform: translateY(-1px); }
  .waiver-programs { background: var(--navy); border-radius: var(--radius); padding: 30px; }
  .waiver-programs h3 { color: var(--white); font-size: 1rem; margin-bottom: 16px; }
  .waiver-programs ul { list-style: none; display: grid; gap: 10px; margin-bottom: 20px; }
  .waiver-programs li { color: rgba(255,255,255,0.85); font-size: 0.9rem; display: flex; gap: 8px; }
  .waiver-programs li::before { content: "✓"; color: var(--gold); font-weight: 700; flex-shrink: 0; }
  .waiver-badges { display: flex; gap: 8px; flex-wrap: wrap; }
  .w-badge { font-size: 0.72rem; font-weight: 700; color: var(--white); border: 1.5px solid rgba(255,255,255,0.35); border-radius: 20px; padding: 4px 11px; }

  .services-cta { background: var(--navy); padding: 64px 0; position: relative; overflow: hidden; }
  .cta-bg-shape { position: absolute; top: -80px; right: -80px; width: 400px; height: 400px; border-radius: 50%; background: rgba(184,144,44,0.08); pointer-events: none; }
  .cta-inner { text-align: center; max-width: 580px; margin: 0 auto; position: relative; z-index: 1; }
  .cta-inner h2 { color: var(--white); font-size: clamp(1.6rem, 3vw, 2rem); margin-bottom: 10px; }
  .cta-inner p { color: rgba(255,255,255,0.75); margin-bottom: 28px; }
  .btn-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-gold { background: var(--gold); color: var(--navy-deep); font-weight: 700; }
  .btn-gold:hover { background: #a07820; transform: translateY(-1px); }
  .btn-ghost-light { background: transparent; color: var(--white); border: 2px solid rgba(255,255,255,0.5); font-weight: 700; }
  .btn-ghost-light:hover { background: rgba(255,255,255,0.1); color: var(--white); }

  .reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.in { opacity: 1; transform: none; }
  .reveal--delay  { transition-delay: 0.15s; }
  .reveal--delay-2 { transition-delay: 0.3s; }

  .living-section { padding: var(--section-pad) 0; background: var(--white); }
  .living-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 28px; }
  .living-card { background: var(--bg-alt); border: 1px solid var(--border); border-top: 4px solid var(--gold); border-radius: var(--radius); padding: 28px 22px; }
  .living-icon { font-size: 1.8rem; margin-bottom: 12px; }
  .living-card h3 { font-family: var(--font-head); font-size: 1rem; color: var(--navy); margin-bottom: 10px; }
  .living-card p { font-size: 0.9rem; color: var(--ink-soft); line-height: 1.65; }
  .living-card strong { color: var(--navy); font-weight: 700; }
  .living-footer { text-align: center; font-size: 1rem; color: var(--ink); font-weight: 600; font-family: var(--font-head); }

@media (max-width: 880px) { .living-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 540px) { .living-grid { grid-template-columns: 1fr; } }

  @media (max-width: 880px) {
    .services-grid { grid-template-columns: 1fr; }
    .dsp-grid { grid-template-columns: 1fr 1fr; }
    .waiver-inner { grid-template-columns: 1fr; }
    .slide { height: 320px; }
    .slide-caption { padding: 30px 20px 20px; }
    .slider-arrow { display: none; }
  }
  @media (max-width: 540px) {
    .dsp-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  let current = 0;
  let paused = false;

  const track = document.getElementById('sliderTrack');
  const dots = document.querySelectorAll('.dot');
  const pauseBtn = document.getElementById('pauseBtn');
  const total = dots.length;

  function goTo(n) {
    current = (n + total) % total;
    if (track) track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => {
      d.classList.toggle('active', i === current);
      d.setAttribute('aria-selected', String(i === current));
    });
  }

  document.getElementById('prevBtn')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('nextBtn')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
  pauseBtn?.addEventListener('click', () => {
    paused = !paused;
    if (pauseBtn) { pauseBtn.textContent = paused ? '▶ Resume' : '❚❚ Pause'; }
  });
  setInterval(() => { if (!paused) goTo(current + 1); }, 4500);

  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); observer.unobserve(e.target); } }),
    { threshold: 0.1 }
  );
  reveals.forEach(el => observer.observe(el));
</script>